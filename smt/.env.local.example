# SMT local development config — copy to .env.local and edit
# .env.local is gitignored.

# PostgreSQL connection
DATABASE_URL=postgresql://user@localhost:5432/smt

# S3-compatible object storage (local MinIO defaults)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=smt-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
