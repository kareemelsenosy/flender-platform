# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (local dev):
DATABASE_URL=sqlite:///./flender.db

# PostgreSQL (production — Neon, Supabase, Railway, or Vercel Postgres):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
APP_BASE_URL=http://localhost:8000
EMAIL_VERIFICATION_REQUIRED=false
INTERNAL_API_ENABLED=false

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
OUTPUT_DIR=./output

# On Vercel (/tmp is the only writable dir):
# UPLOAD_DIR=/tmp/uploads
# OUTPUT_DIR=/tmp/output

# ── AI / Search ───────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
GEMINI_API_KEY=
GOOGLE_SEARCH_KEY=
GOOGLE_CSE_ID=

# ── Docker Compose: Order Sheet platform ──────────────────────────────────────
# Password for the bundled Postgres "db" service (used by docker-compose).
POSTGRES_PASSWORD=change-me

# ── Docker Compose: Social Media Tracker (SMT) ────────────────────────────────
# SMT is served at ordersheet.flendergroup.com/smt (same domain, same login).
# It runs in its own isolated Postgres + MinIO containers.
SMT_DB_PASSWORD=change-me-too
MINIO_ROOT_USER=smtadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
SMT_S3_BUCKET=smt-uploads
